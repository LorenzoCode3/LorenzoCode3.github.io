---
import Layout from "../layouts/Layout.astro";
import WorksCard from "../components/WorksCard.astro";
import WorksCardIcons from "../components/WorksCardIcons.astro";
---

<Layout title="Progetti"> <!-- Portfolio -->
    <WorksCardIcons />

    <div class="container">
        <div class="grid">
            <WorksCard title="Game of life in pygame" date="2024" description="Script python che implementa un'interfaccia visuale per il 'game of life' utilizzando la libreria pygame." link="https://github.com/LorenzoCode3/GameOfLife-pygame" linkLabel="Vai alla repository" icon="#codeSlash"/>
            <WorksCard title="#36DaysOfType art challenge" date="2023" description="Raccolta degli artwork realizzati in Blender per la challenge, un render al giorno per 36 giorni." link="/36DaysChallenge2023/" linkLabel="Vai alla pagina" icon="#palette"/>
            <WorksCard title="Blender portfolio" date="2019 - Adesso" description="Raccolta di artwork realizzati durante gli anni." link="/blenderPortfolio/" linkLabel="Vai alla pagina" icon="#palette"/>
        </div>
        <div class="grid">
            <div/>
            <div/>
            <div/>
        </div>
    </div>
</Layout>