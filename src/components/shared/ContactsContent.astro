---
import ContactCard from "../ContactCard.astro";
import { t } from "../../i18n/utils.ts";
export interface Props { lang: string }
const { lang } = Astro.props as Props;

const textGithub = t(lang, 'contacts.textGithub');
const textFacebook = t(lang, 'contacts.textFacebook');
const textInstagram = t(lang, 'contacts.textInstagram');
const textLinkedin = t(lang, 'contacts.textLinkedin');
const textBehance = t(lang, 'contacts.textBehance');
const textSuperprof = t(lang, 'contacts.textSuperprof');
const pageTitle = t(lang, 'contacts.title');
---

<div class="container px-5 py-8 mx-auto">
    <h1 class="title-font sm:text-4xl text-3xl">{pageTitle}</h1>
</div>
<div class="container px-5 py-8 mx-auto">
    <div class="flex flex-wrap -m-4">
        <ContactCard title="Github" text={textGithub} link="https://github.com/LorenzoCode3" icon="github" />
        <ContactCard title="Behance" text={textBehance} link="https://www.behance.net/lorenzoera/projects" icon="behance" />
        <ContactCard title="Linkedin" text={textLinkedin} link="https://it.linkedin.com/in/lorenzo-era-it" icon="linkedin" />
        <ContactCard title="Facebook" text={textFacebook} link="https://www.facebook.com/lorenzo.era.3" icon="facebook" />
        <ContactCard title="Instagram" text={textInstagram} link="https://www.instagram.com/lorenzoera_/" icon="instagram" />
        <ContactCard title="Superprof" text={textSuperprof} link="https://www.superprof.it/studente-ingegneria-informatica-propone-lezioni-informatica-matematica-per-medie-superiori-zona-carbonia-iglesias.html" icon="fa-solid fa-s" />
    </div>
</div>
