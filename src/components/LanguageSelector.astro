---
// Language Selector Component - Smart switching that maintains current page
const currentUrl = Astro.url.pathname;
const isItalian = currentUrl.startsWith('/it');

// Get the current page path (remove language prefix if present)
const getBasePath = (url: string): string => {
  if (url.startsWith('/it/')) {
    return url.substring(3); // Remove /it/ prefix
  }
  if (url === '/it') {
    return '/';
  }
  return url;
};

const basePath = getBasePath(currentUrl);

// Generate target URL (toggle language)
const targetUrl = isItalian 
  ? (basePath === '/' ? '/' : basePath)
  : (basePath === '/' ? '/it/' : `/it${basePath}`);

// Show opposite language flag
const toggleFlag = isItalian ? 'IT' : 'EN'; //'🇮🇹' : '🇬🇧';
const toggleName = isItalian ? 'English' : 'Italiano';
---

<a
  href={targetUrl}
  class="lang-button"
  title={toggleName}
>
  {toggleFlag}
</a>

<style is:global>
  .lang-button {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1.125rem;
    color: #9ca3af;
    transition: all 0.3s ease;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    padding: 0;
    border: 2px solid rgba(99, 102, 241, 0.12);
    /*background: transparent;*/
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.04) 0%, rgba(99, 102, 241, 0.02) 100%);
  }

  html.light .lang-button {
    color: #6b7280;
  }

  /* Keep border visible in light mode with a slightly different tint */
  html.light .lang-button {
    border-color: rgba(59, 130, 246, 0.12);
  }

  html.dark .lang-button {
    color: #9ca3af;
  }

  .lang-button:hover {
    transform: scale(1.08);
    border-color: rgba(99, 102, 241, 0.14);
    background-color: rgba(99, 102, 241, 0.03);
  }

  html.light .lang-button:hover {
    color: #4f46e5;
  }

  html.dark .lang-button:hover {
    color: #818cf8;
  }
</style>
