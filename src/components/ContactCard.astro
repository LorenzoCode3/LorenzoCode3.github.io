---
import { t, getLanguageFromURL } from "../i18n/utils.ts";

const { title, text, link, icon, learnMoreText } = Astro.props;
const lang = getLanguageFromURL(Astro.url);
const localLearnMore = learnMoreText ?? t(lang, 'projects.learnMore');
---

<div class="p-4 md:w-1/3">
    <div class="flex rounded-lg h-full bg-gray-800 dark-card p-8 flex-col">
        <div class="flex items-center mb-3">
            <div
                class="w-8 h-8 mr-3 inline-flex items-center justify-center rounded-full bg-indigo-500 text-white flex-shrink-0"
            >
                <i class={`fa-brands fa-${icon}`}></i>
            </div>
            <h2
                class="text-gray-300 dark-card-title text-lg title-font font-medium"
            >
                {title}
            </h2>
        </div>
        <div class="flex-grow">
            <p class="leading-relaxed text-gray-400 dark-card-text text-base">
                {text}
            </p>
            <a class="mt-3 text-indigo-500 inline-flex items-center gap-2" href={link}
                >{localLearnMore}
                <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
    </div>
</div>

<style is:global>
    /* Contact card dark mode */
    html.dark .dark-card {
        background-color: #1f2937; /* gray-800 */
    }

    html.dark .dark-card-title {
        color: #d1d5db; /* gray-300 */
    }

    html.dark .dark-card-text {
        color: #9ca3af; /* gray-400 */
    }

    /* Contact card light mode */
    html.light .dark-card {
        background-color: #f3f4f6; /* gray-100 */
    }

    html.light .dark-card-title {
        color: #374151; /* gray-700 */
    }

    html.light .dark-card-text {
        color: #4b5563; /* gray-600 */
    }
</style>