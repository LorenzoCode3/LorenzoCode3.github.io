---
import { t, getLanguageFromURL } from "../i18n/utils.ts";

const { category, date, title, text, link, learnMoreText } = Astro.props;
const lang = getLanguageFromURL(Astro.url);
const localLearnMore = learnMoreText ?? t(lang, 'projects.learnMore');
---
<div class="py-8 flex flex-wrap md:flex-nowrap">
    <div
        class="md:w-64 md:mb-0 mb-6 flex-shrink-0 flex flex-col"
    >
        <span class="font-semibold title-font text-gray-400 project-category"
            >{category}</span
        >
        <span class="mt-1 text-gray-500 project-date text-sm"
            >{date}</span
        >
    </div>
    <div class="md:flex-grow">
        <h2
            class="text-2xl font-medium text-gray-300 project-title title-font mb-2"
        >
            {title}
        </h2>
        <p class="leading-relaxed text-gray-400 project-text">
            {text}
        </p>
        <a class="text-indigo-500 inline-flex items-center mt-4 gap-2" href={link}
            >{localLearnMore}
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</div>

<style is:global>
    /* ProjectCard dark mode (default for dark cards) */
    html.dark .project-category {
        color: #9ca3af; /* gray-400 */
    }

    html.dark .project-date {
        color: #6b7280; /* gray-500 */
    }

    html.dark .project-title {
        color: #d1d5db; /* gray-300 */
    }

    html.dark .project-text {
        color: #9ca3af; /* gray-400 */
    }

    /* ProjectCard light mode */
    html.light .project-category {
        color: #6b7280; /* gray-500 */
    }

    html.light .project-date {
        color: #9ca3af; /* gray-400 */
    }

    html.light .project-title {
        color: #111827; /* gray-900 */
    }

    html.light .project-text {
        color: #4b5563; /* gray-600 */
    }
</style>